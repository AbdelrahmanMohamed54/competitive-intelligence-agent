# Primary LLM — Google AI Studio (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Model override (optional — defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Fallback LLM — Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

# Web search — Tavily (https://app.tavily.com/home)
TAVILY_API_KEY=your_tavily_key_here

# Observability — Langfuse (https://cloud.langfuse.com)
# Leave empty to disable tracing (pipeline still runs normally)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
# LANGFUSE_HOST=https://cloud.langfuse.com
